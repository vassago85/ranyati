# Ranyati Group - Production Environment
# Copy this to /opt/ranyati/.env and fill in the values

# App Key - generate with: docker compose exec app php artisan key:generate --show
APP_KEY=

# Database
DB_ROOT_PASSWORD=CHANGE_ME
DB_DATABASE=ranyati
DB_USERNAME=ranyati
DB_PASSWORD=CHANGE_ME

# URL
APP_URL=https://ranyati.co.za
APP_PORT=8087

# Admin user (used on first deploy seed)
ADMIN_EMAIL=paul@charsley.co.za
ADMIN_PASSWORD=CHANGE_ME

# Mailgun
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS=noreply@ranyati.co.za
MAIL_FROM_NAME=Ranyati Group
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.eu.mailgun.net

# Ntfy (optional)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
